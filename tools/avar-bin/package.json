{
  "name": "@aarmos/avar-bin",
  "version": "1.0.0",
  "description": "Standalone AVAR receipt verifier — single-file executable, no Node required. Built with bun --compile.",
  "private": true,
  "type": "module",
  "scripts": {
    "build:host": "bun build ./avar.ts --compile --minify --outfile out/avar",
    "build:linux-x64": "bun build ./avar.ts --compile --minify --target=bun-linux-x64 --outfile out/avar-linux-x64",
    "build:linux-arm64": "bun build ./avar.ts --compile --minify --target=bun-linux-arm64 --outfile out/avar-linux-arm64",
    "build:darwin-x64": "bun build ./avar.ts --compile --minify --target=bun-darwin-x64 --outfile out/avar-darwin-x64",
    "build:darwin-arm64": "bun build ./avar.ts --compile --minify --target=bun-darwin-arm64 --outfile out/avar-darwin-arm64",
    "build:windows-x64": "bun build ./avar.ts --compile --minify --target=bun-windows-x64 --outfile out/avar-windows-x64.exe",
    "build": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64 && (cd out && sha256sum avar-* > SHA256SUMS)"
  },
  "dependencies": {
    "@aarmos/avar-core": "1.0.0",
    "fflate": "^0.8.3"
  }
}
